/* pages/test/test.ttss - API测试页面样式 */

.container {
  min-height: 100vh;
  padding: 30rpx;
  background: var(--primary-bg);
}

/* 页面标题 */
.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.header .title {
  font-size: 48rpx;
  font-weight: 600;
  color: var(--primary-text);
  display: block;
  margin-bottom: 10rpx;
}

.header .subtitle {
  font-size: 28rpx;
  color: var(--secondary-text);
  display: block;
}

/* 测试按钮区域 */
.test-buttons {
  margin-bottom: 40rpx;
}

.test-section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--primary-text);
  display: block;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
  border-left: 4rpx solid var(--accent-color);
}

.test-btn {
  width: 100%;
  margin-bottom: 20rpx;
  padding: 25rpx;
  font-size: 30rpx;
  border-radius: var(--radius);
  transition: all 0.3s ease;
}

.test-btn:active {
  transform: scale(0.98);
}

/* 加载状态 */
.loading-section {
  text-align: center;
  padding: 60rpx 0;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--border-color);
  border-top: 4rpx solid var(--accent-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

.loading-text {
  font-size: 28rpx;
  color: var(--secondary-text);
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 测试结果区域 */
.results-section {
  margin-top: 40rpx;
}

.result-list {
  margin-top: 20rpx;
}

.result-item {
  margin-bottom: 30rpx;
  padding: 30rpx;
  background: var(--card-bg);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  border: 1px solid var(--border-color);
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.result-name {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--primary-text);
}

.result-status {
  font-size: 24rpx;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.result-status.success {
  background: rgba(76, 175, 80, 0.1);
  color: #4CAF50;
}

.result-status.error {
  background: rgba(244, 67, 54, 0.1);
  color: #F44336;
}

.result-time {
  font-size: 22rpx;
  color: var(--secondary-text);
  display: block;
  margin-bottom: 20rpx;
}

.result-content {
  margin-top: 20rpx;
}

.result-label {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--primary-text);
  display: block;
  margin-bottom: 8rpx;
}

.result-text {
  font-size: 24rpx;
  color: var(--secondary-text);
  line-height: 1.5;
  display: block;
  margin-bottom: 15rpx;
  word-break: break-all;
  white-space: pre-wrap;
  max-height: 200rpx;
  overflow-y: auto;
  background: rgba(0, 0, 0, 0.02);
  padding: 15rpx;
  border-radius: 8rpx;
}

.result-error {
  font-size: 24rpx;
  color: #F44336;
  line-height: 1.5;
  display: block;
  margin-bottom: 15rpx;
  word-break: break-all;
  white-space: pre-wrap;
  background: rgba(244, 67, 54, 0.05);
  padding: 15rpx;
  border-radius: 8rpx;
}

.result-response {
  position: relative;
}

.copy-btn {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  background: var(--accent-color);
  color: white;
  border: none;
  padding: 8rpx 16rpx;
  font-size: 22rpx;
  border-radius: 6rpx;
  cursor: pointer;
}

.copy-btn:active {
  background: #C49564;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: var(--secondary-text);
}

/* 响应式调整 */
@media (max-width: 750rpx) {
  .container {
    padding: 20rpx;
  }
  
  .header .title {
    font-size: 40rpx;
  }
  
  .test-btn {
    padding: 20rpx;
    font-size: 28rpx;
  }
} 